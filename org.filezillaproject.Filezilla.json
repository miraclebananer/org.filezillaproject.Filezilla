{
  "id": "org.filezillaproject.Filezilla",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "filezilla",
  "rename-icon": "filezilla",
  "copy-icon": true,
  "rename-desktop-file": "filezilla.desktop",
  "finish-args": [
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--talk-name=org.freedesktop.PowerManagement",
    "--talk-name=org.freedesktop.Notifications",
    "--talk-name=org.gnome.SessionManager",
    "--filesystem=host",
    "--share=network",
    "--socket=ssh-auth"
  ],
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/lib/*.a",
    "/lib/*.la",
    "/share/aclocal"
  ],
  "modules": [
    "shared-modules/glu/glu-9.json",
    {
      "name": "boost",
      "sources": [
        {
          "x-checker-data": {
            "type": "anitya",
            "project-id": 6845,
            "url-template": "https://archives.boost.io/release/$version/source/boost_${major}_${minor}_${patch}.tar.bz2"
          },
          "type": "archive",
          "url": "https://archives.boost.io/release/1.90.0/source/boost_1_90_0.tar.bz2",
          "sha256": "49551aff3b22cbc5c5a9ed3dbc92f0e23ea50a0f7325b0d198b705e8ee3fc305"
        }
      ],
      "buildsystem": "simple",
      "build-commands": [
        "./bootstrap.sh",
        "./b2 install --prefix=/app/ variant=release link=static threading=multi --with-regex -j $FLATPAK_BUILDER_N_JOBS"
      ],
            "cleanup": [
                "/lib/",
                ""
            ]
    },
    {
      "name": "wxWidgets",
            "cleanup": [
                "/bin",
                "/share/bakefile"
            ],
      "config-opts": [
        "--without-opengl",
        "--with-libjpeg",
        "--with-libtiff",
        "--with-libpng",
        "--with-zlib",
        "--disable-sdltest",
        "--enable-unicode",
        "--enable-display",
        "--enable-propgrid",
        "--disable-webview",
        "--disable-webviewwebkit",
        "--with-expat=builtin",
        "--with-libiconv=/usr"
      ],
      "build-options": {
        "cxxflags": "-std=c++0x"
      },
      "sources": [
        {
          "x-checker-data": {
            "type": "json",
            "url": "https://api.github.com/repos/wxWidgets/wxWidgets/releases/latest",
            "version-query": ".tag_name | sub(\"^v\"; \"\")",
            "url-query": ".assets[] | select(.name==\"wxWidgets-\" + $version + \".tar.bz2\") | .browser_download_url"
          },
          "type": "archive",
          "url": "https://github.com/wxWidgets/wxWidgets/releases/download/v3.2.10/wxWidgets-3.2.10.tar.bz2",
          "sha256": "d66e929569947a4a5920699539089a9bda83a93e5f4917fb313a61f0c344b896"
        }
      ]
    },
    {
      "name": "libfilezilla",
      "sources": [
        {
          "x-checker-data": {
            "type": "html",
            "//": "filezilla-project.org blocks fedc user agent",
            "url": "https://sources.archlinux.org/other/packages/libfilezilla/",
            "pattern": "libfilezilla-([0-9.]+)\\.tar\\.xz",
            "is-important": true
          },
          "type": "archive",
          "url": "https://sources.archlinux.org/other/packages/libfilezilla/libfilezilla-0.56.1.tar.xz",
          "sha512": "b488968ea8d0f8b4b83f45755303bf94a0118cded5fe911a187c532962e2445c2e2851311229cddcec3141d9e0d0a84076927812cd9a78b83ca0693dcc23fbfd"
        }
      ]
    },
    {
      "name": "filezilla",
      "config-opts": [
        "--disable-autoupdatecheck",
        "--disable-manualupdatecheck",
        "--with-pugixml=builtin"
      ],
            "cleanup": [
                "/share/pixmaps",
                "/share/man"
            ],
      "post-install": [
        "install -Dm644 org.filezillaproject.Filezilla.metainfo.xml ${FLATPAK_DEST}/share/metainfo/org.filezillaproject.Filezilla.metainfo.xml",
        "rm /app/share/appdata/filezilla.appdata.xml"
      ],
      "sources": [
        {
          "x-checker-data": {
            "type": "html",
            "//": "filezilla-project.org blocks fedc user agent",
            "url": "https://sources.archlinux.org/other/filezilla/",
            "pattern": "filezilla-([0-9.]+)\\.tar\\.xz",
            "is-main-source": true
          },
          "type": "archive",
          "url": "https://sources.archlinux.org/other/filezilla/filezilla-3.70.6.tar.xz",
          "sha512": "22c8315adc4ba43868c2b0d4fdfc49ff063e3fd4817907cc5f53aa3837158ca58fd516280db406699daed5b07f16d52bc47f7034f6c32252063bec4316f8a154"
        },
        {
          "type": "file",
          "path": "org.filezillaproject.Filezilla.metainfo.xml"
        },
        {
          "type": "patch",
          "path": "0001-Correct-notification-icon-and-app-name.patch"
        },
        {
          "type": "patch",
          "path": "desktop-file-mime.patch"
        }
      ]
    }
  ]
}
